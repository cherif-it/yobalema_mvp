generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Booking {
  id            String        @id
  transporterId String
  shipmentId    String
  status        BookingStatus @default(PENDING)
  createdAt     DateTime      @default(now())
  Shipment      Shipment      @relation(fields: [shipmentId], references: [id])
  User          User          @relation(fields: [transporterId], references: [id])
}

model ExpeditorProfile {
  id     String @id
  userId String @unique
  User   User   @relation(fields: [userId], references: [id])
}

model Shipment {
  id          String         @id
  title       String
  description String
  origin      String
  destination String
  date        DateTime
  weight      Float
  status      ShipmentStatus @default(PENDING)
  createdAt   DateTime       @default(now())
  expeditorId String
  Booking     Booking[]
  User        User           @relation(fields: [expeditorId], references: [id])
}

model TransportAvailability {
  id            String    @id
  fromLocation  String
  toLocation    String
  departureDate DateTime
  returnDate    DateTime?
  capacity      Float
  notes         String?
  createdAt     DateTime  @default(now())
  transporterId String
  arrivalDate   DateTime?
  User          User      @relation(fields: [transporterId], references: [id])
}

model TransporterProfile {
  id     String @id
  userId String @unique
  User   User   @relation(fields: [userId], references: [id])
}

model User {
  id                    String                  @id
  name                  String?
  email                 String                  @unique
  password              String
  role                  Role                    @default(EXPEDITOR)
  createdAt             DateTime                @default(now())
  nom                   String
  prenom                String
  Booking               Booking[]
  ExpeditorProfile      ExpeditorProfile?
  Shipment              Shipment[]
  TransportAvailability TransportAvailability[]
  TransporterProfile    TransporterProfile?
}

enum BookingStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
}

enum Role {
  EXPEDITOR
  TRANSPORTER
}

enum ShipmentStatus {
  PENDING
  BOOKED
  IN_TRANSIT
  DELIVERED
  CANCELLED
}
